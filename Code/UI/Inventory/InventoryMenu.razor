@using Sandbox;
@using Sandbox.UI;
@namespace Sandbox
@inherits PanelComponent

@{
	var storage = Storage;
	var inv = Inventory;
}

@if ( storage is null || inv is null )
	return;

@if ( !IsOpen )
	return;

<root>
	<div class="inv-window">

		<div class="inv-header">
			<label class="inv-title">Inventaire — Sac à dos (@storage.Entries.Count / @storage.MaxSlots)</label>
			<button class="inv-close" onclick=@Close>✕</button>
		</div>

		<!-- Grille de stockage -->
		<div class="inv-grid">
			@for ( int i = 0; i < storage.MaxSlots; i++ )
			{
				var idx = i;
				@if ( i < storage.Entries.Count )
				{
					var entry = storage.Entries[i];
					<div class="inv-slot filled" onclick=@(() => storage.RetrieveToHotbar( idx ))>
						<div class="inv-slot-icon" style="background-image: url('@entry.IconPath')"></div>
						<label class="inv-slot-name">@entry.DisplayName</label>
						@if ( entry.AmmoCount > 0 )
						{
							<label class="inv-slot-ammo">@entry.AmmoCount</label>
						}
						<button class="inv-drop-btn" onclick=@(( PanelEvent e ) => { e.StopPropagation(); storage.DropFromStorage( idx ); })>⬇</button>
					</div>
				}
				else
				{
					<div class="inv-slot empty"></div>
				}
			}
		</div>

		<div class="inv-divider">
			<label>— Armes équipées — cliquez pour ranger —</label>
		</div>

		<!-- Hotbar -->
		<div class="inv-hotbar">
			@for ( int i = 0; i < inv.MaxSlots; i++ )
			{
				var weapon = inv.GetSlot( i );
				var slotIdx = i;
				@if ( weapon.IsValid() )
				{
					<div class="inv-slot hotbar-slot @(weapon.IsJobLocked || weapon is CameraWeapon ? "locked" : "") @(inv.ActiveWeapon == weapon ? "active" : "")"
						 onclick=@(() => TransferToStorage( weapon ))>
						<div class="inv-slot-icon" style="background-image: url('@GetIcon( weapon )')"></div>
						<label class="inv-slot-name">@weapon.DisplayName</label>
						@if ( weapon is BaseWeapon bw && bw.UsesAmmo )
						{
							<label class="inv-slot-ammo">@bw.ReserveAmmo</label>
						}
						<label class="inv-slot-index">@(slotIdx + 1)</label>
					</div>
				}
				else
				{
					<div class="inv-slot empty hotbar-slot">
						<label class="inv-slot-index">@(slotIdx + 1)</label>
					</div>
				}
			}
		</div>

	</div>
</root>

@code {
	public bool IsOpen { get; private set; }

	PlayerStorage Storage;
	PlayerInventory Inventory;

	protected override int BuildHash() =>
		HashCode.Combine( IsOpen, Storage?.StorageJson, Inventory?.ActiveWeapon, Inventory?.Weapons.Count() );

	protected override void OnUpdate()
	{
		Storage = Game.ActiveScene.GetAllComponents<PlayerStorage>().FirstOrDefault( x => !x.IsProxy );
		Inventory = Game.ActiveScene.GetAllComponents<PlayerInventory>().FirstOrDefault( x => !x.IsProxy );
	}

	public void ToggleOpen()
	{
		IsOpen = !IsOpen;
		Mouse.Visible = IsOpen;
		StateHasChanged();
	}

	void Close()
	{
		IsOpen = false;
		Mouse.Visible = false;
	}

	void TransferToStorage( BaseCarryable weapon )
	{
		if ( !weapon.IsValid() || weapon.IsJobLocked || weapon is CameraWeapon ) return;
		Storage?.StoreWeapon( weapon );
	}

	string GetIcon( BaseCarryable weapon )
	{
		if ( !weapon.IsValid() ) return string.Empty;
		var icon = weapon.InventoryIconOverride;
		if ( !string.IsNullOrEmpty( icon ) ) return icon;
		return weapon.DisplayIcon?.ResourcePath ?? string.Empty;
	}
}
